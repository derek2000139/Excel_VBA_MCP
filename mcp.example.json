{
  "mcpServers": {
    "excel-core": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "excelforge.gateway.core",
        "--config",
        "D:/ExcelForge/excel-core-mcp.yaml"
      ],
      "cwd": "D:/ExcelForge"
    },
    "excel-vba": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "excelforge.gateway.vba",
        "--config",
        "D:/ExcelForge/excel-vba-mcp.yaml"
      ],
      "cwd": "D:/ExcelForge"
    },
    "excel-recovery": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "excelforge.gateway.recovery",
        "--config",
        "D:/ExcelForge/excel-recovery-mcp.yaml"
      ],
      "cwd": "D:/ExcelForge"
    },
    "excel-pq": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "excelforge.gateway.pq",
        "--config",
        "D:/ExcelForge/excel-pq-mcp.yaml"
      ],
      "cwd": "D:/ExcelForge"
    }
  }
}
